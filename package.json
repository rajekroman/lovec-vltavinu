{
  "name": "lovec-vltavinu-webgame",
  "private": true,
  "version": "0.15.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:network": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "preview:network": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "assets:models": "node scripts/generate-glb-assets.mjs",
    "release:verify": "npm test && npm run build && node scripts/verify-release.mjs",
    "release:archive": "npm run release:verify && node scripts/create-release-archive.mjs"
  },
  "dependencies": {
    "three": "0.185.1"
  },
  "devDependencies": {
    "@types/three": "0.185.1",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "^4.1.10"
  }
}
